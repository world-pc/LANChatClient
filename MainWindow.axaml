<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="LANChatClient.MainWindow"
        Title="LANChatClient"
        Height="300"
        Width="600"
        Opened="MainWindow_Opened">
    <StackPanel>

        <TextBlock Text="Welcome to LAN Chat Client" Margin="10"/>

        <StackPanel Orientation="Horizontal">

            <ListBox Name="chatlog" Height="200" MinWidth="500" />
            <Border Width="1" Background="Gray" />
            <ListBox Name="lobby" Height="200">
                <TextBlock Text="user a" />
                <TextBlock Text="user b" />
                <TextBlock Text="user c" />
            </ListBox>
        </StackPanel>

        <StackPanel Orientation="Horizontal">
            <TextBox Name="usrMsgInput" KeyDown="UsrMsgInput_KeyDown" MinWidth="200" />
            <Button Content="send" Click="SendButton_Click" />
        </StackPanel>

    </StackPanel>
</Window>
